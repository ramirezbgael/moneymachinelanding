# Supabase — https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Stripe Checkout (precios por industria) — copia IDs price_... desde Stripe Dashboard
# Commerce
VITE_STRIPE_PRICE_RETAIL_BASICO_MONTHLY=
VITE_STRIPE_PRICE_RETAIL_BASICO_YEARLY=
VITE_STRIPE_PRICE_RETAIL_PRO_MONTHLY=
VITE_STRIPE_PRICE_RETAIL_PRO_YEARLY=

# Gym
VITE_STRIPE_PRICE_GYM_MONTHLY=
VITE_STRIPE_PRICE_GYM_YEARLY=

# Restaurant
VITE_STRIPE_PRICE_RESTAURANT_STARTER_MONTHLY=
VITE_STRIPE_PRICE_RESTAURANT_STARTER_YEARLY=
VITE_STRIPE_PRICE_RESTAURANT_PRO_MONTHLY=
VITE_STRIPE_PRICE_RESTAURANT_PRO_YEARLY=
VITE_STRIPE_PRICE_RESTAURANT_PREMIUM_MONTHLY=
VITE_STRIPE_PRICE_RESTAURANT_PREMIUM_YEARLY=

# Stripe / Edge Functions (NO pongas service_role ni secret key en este archivo):
# Las Edge Functions reciben solas: SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY
# (no puedes hacer "supabase secrets set SUPABASE_*" — está reservado e inyectado por Supabase).
#
# Solo configura por CLI:
#   supabase secrets set STRIPE_SECRET_KEY=sk_test_xxx
#   supabase secrets set STRIPE_WEBHOOK_SECRET=whsec_xxx
#   supabase functions deploy create-checkout-session --no-verify-jwt
#   supabase functions deploy stripe-webhook --no-verify-jwt
#   supabase functions deploy send-business-invite --no-verify-jwt
# SQL: supabase/migration_009_stripe_subscriptions.sql
# Webhook URL en Stripe: https://<ref>.supabase.co/functions/v1/stripe-webhook

# Invite email (también por secrets, no en .env del cliente):
#   supabase secrets set RESEND_API_KEY=re_xxx
#   supabase secrets set INVITE_FROM_EMAIL=equipo@tu-dominio.com
#   supabase secrets set APP_BASE_URL=http://localhost:5173


